<?xml version="1.0" encoding="utf-8"?>
<!--
    Amostra ESTÁTICA (sem dados reais) mostrada pelo sistema na tela de "adicionar widget", antes
    de o usuário confirmar. Referenciada por android:previewLayout em xml/versiculo_widget_info.xml.
    Usa um versículo universal (João 3:16) porque é a mesma amostra para qualquer tema/categoria
    que o usuário só escolhe depois de instalar o widget - não deve chamar nenhum código do app
    (por isso é um layout Android comum, não Glance): antes disso o sistema só tinha
    glance_default_loading_layout, que ficava preso em "carregando".
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="260dp"
    android:layout_height="150dp"
    android:background="@drawable/widget_preview_card_bg">

    <!-- FrameLayout no lugar de View: RemoteViews (usado tanto no widget real quanto neste
         preview) só permite inflar um conjunto restrito de classes, e android.view.View puro
         não está nessa lista (falha com "Class not allowed to be inflated"). -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:background="@color/widget_preview_primary" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingTop="14dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/widget_preview_badge_bg"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:text="@string/app_name"
                android:textAllCaps="true"
                android:textColor="@color/widget_preview_primary"
                android:textSize="10sp"
                android:textStyle="bold" />

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="@string/app_name"
                android:src="@mipmap/ic_launcher" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="@string/app_name"
                android:textAllCaps="true"
                android:textColor="@color/widget_preview_text_muted"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="serif"
                android:text="&#8220;"
                android:textColor="@color/widget_preview_primary"
                android:textSize="30sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:fontFamily="serif"
                android:gravity="center"
                android:maxLines="4"
                android:text="@string/widget_preview_verse_text"
                android:textColor="@color/widget_preview_text"
                android:textSize="18sp"
                android:textStyle="italic" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/widget_preview_verse_reference"
                android:textColor="@color/widget_preview_primary"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
